generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String
  role         Role               @default(USER)
  expireAt     DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  progress     UserVideoProgress[]
  wordBag      UserWordBag[]
}

enum Role {
  USER
  ADMIN
}

model Category {
  id        String          @id @default(cuid())
  name      String
  nameZh    String
  type      CategoryType
  slug      String          @unique
  sortOrder Int             @default(0)
  videos    VideoCategory[]
}

enum CategoryType {
  LEVEL
  TOPIC
}

model Video {
  id                String          @id @default(cuid())
  title             String
  titleZh           String
  description       String?
  descriptionZh     String?
  coverUrl          String
  videoUrl          String
  audioUrl          String?
  duration          Int
  episodeNumber     Int?
  difficulty        Int?
  instructor        String?
  published         Boolean         @default(false)
  visitorAccessible Boolean         @default(false)
  vodVideoId        String?         @unique
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  categories        VideoCategory[]
  subtitleTracks    SubtitleTrack[]
  progress          UserVideoProgress[]
  words             VideoWord[]
}

model VideoCategory {
  videoId    String
  categoryId String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([videoId, categoryId])
}

model SubtitleTrack {
  id      String          @id @default(cuid())
  videoId String
  lang    SubtitleLang
  video   Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  entries SubtitleEntry[]

  @@unique([videoId, lang])
}

enum SubtitleLang {
  KO
  ZH
}

model SubtitleEntry {
  id        String        @id @default(cuid())
  trackId   String
  index     Int
  startTime Float
  endTime   Float
  text      String
  track     SubtitleTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model UserVideoProgress {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  completed Boolean  @default(false)
  progress  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Feedback {
  id        String   @id @default(cuid())
  type      String
  content   String
  contact   String
  createdAt DateTime @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
}

model VideoWord {
  id        String        @id @default(cuid())
  videoId   String
  word      String
  meaning   String
  meaningZh String
  entryId   String?
  startTime Float?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  video     Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userBags  UserWordBag[]

  @@unique([videoId, word])
}

model UserWordBag {
  id        String    @id @default(cuid())
  userId    String
  wordId    String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  word      VideoWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
}
